<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/main_style.css" />
    <script src="/config.js" defer></script>
    <script type="module" src="/js/production_products.js" defer></script>
    <title>Quản Lý Sản Phẩm - Factory Management</title>
  </head>
  <body>
    <!-- Top Navigation Bar -->
    <div class="topBar">
      <a href="/" class="nav-left">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12.707 2.293l9 9c.63 .63 .184 1.707 -.707 1.707h-1v6a3 3 0 0 1 -3 3h-1v-7a3 3 0 0 0 -2.824 -2.995l-.176 -.005h-2a3 3 0 0 0 -3 3v7h-1a3 3 0 0 1 -3 -3v-6h-1c-.89 0 -1.337 -1.077 -.707 -1.707l9 -9a1 1 0 0 1 1.414 0m.293 11.707a1 1 0 0 1 1 1v7h-4v-7a1 1 0 0 1 .883 -.993l.117 -.007z"
          />
        </svg>
        <span>DashBoard</span>
      </a>
      <div class="nav-breadcrumb">
        <a href="/products" style="text-decoration: none; color: inherit"
          >Sản Phẩm</a
        >
      </div>
    </div>

    <!-- Main Container -->
    <div class="main-container-product">
      <!-- Header Section -->
      <div class="header-section">
        <div class="header-top">
          <a class="back-btn" href="/">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#999999"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12l14 0" />
              <path d="M5 12l6 6" />
              <path d="M5 12l6 -6" />
            </svg>
          </a>
          <div class="header-title">
            <div class="header-top-left">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="#6259ee"
              >
                <path
                  d="M11.132 2.504l-4 7a1 1 0 0 0 .868 1.496h8a1 1 0 0 0 .868 -1.496l-4 -7a1 1 0 0 0 -1.736 0z"
                />
                <path
                  d="M17 13a4 4 0 1 1 -3.995 4.2l-.005 -.2l.005 -.2a4 4 0 0 1 3.995 -3.8z"
                />
                <path
                  d="M9 13h-4a2 2 0 0 0 -2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2 -2v-4a2 2 0 0 0 -2 -2z"
                />
              </svg>
              <div class="header-text">
                <h1>Danh Mục Sản Phẩm</h1>
                <p>Quản lý dữ liệu chính sản phẩm và quy đổi đơn vị</p>
              </div>
            </div>
            <div class="badge-cs1"><%= process.env.LINE %></div>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header">
              <span>Tổng Sản Phẩm</span>
              <div class="stat-icon" id="total-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="#2a65b9"
                >
                  <path
                    d="M11.132 2.504l-4 7a1 1 0 0 0 .868 1.496h8a1 1 0 0 0 .868 -1.496l-4 -7a1 1 0 0 0 -1.736 0z"
                  />
                  <path
                    d="M17 13a4 4 0 1 1 -3.995 4.2l-.005 -.2l.005 -.2a4 4 0 0 1 3.995 -3.8z"
                  />
                  <path
                    d="M9 13h-4a2 2 0 0 0 -2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2 -2v-4a2 2 0 0 0 -2 -2z"
                  />
                </svg>
              </div>
            </div>
            <div class="stat-number" id="totalProducts">2</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span>Sản Phẩm Hoạt động</span>
              <div class="stat-icon" id="active-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="#47b54d"
                >
                  <path
                    d="M17 3.34a10 10 0 1 1 -14.995 8.984l-.005 -.324l.005 -.324a10 10 0 0 1 14.995 -8.336zm-1.293 5.953a1 1 0 0 0 -1.32 -.083l-.094 .083l-3.293 3.292l-1.293 -1.292l-.094 -.083a1 1 0 0 0 -1.403 1.403l.083 .094l2 2l.094 .083a1 1 0 0 0 1.226 0l.094 -.083l4 -4l.083 -.094a1 1 0 0 0 -.083 -1.32z"
                  />
                </svg>
              </div>
            </div>
            <div class="stat-number" id="activeProducts">2</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span>Type / Category</span>
              <div class="stat-icon" id="type-category-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 640 640"
                  fill="#1c96ff"
                >
                  <path
                    d="M64 128C64 110.3 78.3 96 96 96L544 96C561.7 96 576 110.3 576 128L576 160C576 177.7 561.7 192 544 192L96 192C78.3 192 64 177.7 64 160L64 128zM96 240L544 240L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 240zM248 304C234.7 304 224 314.7 224 328C224 341.3 234.7 352 248 352L392 352C405.3 352 416 341.3 416 328C416 314.7 405.3 304 392 304L248 304z"
                  />
                </svg>
              </div>
            </div>
            <div class="stat-number" id="totalTypes&Categories">2 / 3</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span>Group</span>
              <div class="stat-icon" id="group-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 640 640"
                  fill="#1c96ff"
                >
                  <path
                    d="M296.5 69.2C311.4 62.3 328.6 62.3 343.5 69.2L562.1 170.2C570.6 174.1 576 182.6 576 192C576 201.4 570.6 209.9 562.1 213.8L343.5 314.8C328.6 321.7 311.4 321.7 296.5 314.8L77.9 213.8C69.4 209.8 64 201.3 64 192C64 182.7 69.4 174.1 77.9 170.2L296.5 69.2zM112.1 282.4L276.4 358.3C304.1 371.1 336 371.1 363.7 358.3L528 282.4L562.1 298.2C570.6 302.1 576 310.6 576 320C576 329.4 570.6 337.9 562.1 341.8L343.5 442.8C328.6 449.7 311.4 449.7 296.5 442.8L77.9 341.8C69.4 337.8 64 329.3 64 320C64 310.7 69.4 302.1 77.9 298.2L112 282.4zM77.9 426.2L112 410.4L276.3 486.3C304 499.1 335.9 499.1 363.6 486.3L527.9 410.4L562 426.2C570.5 430.1 575.9 438.6 575.9 448C575.9 457.4 570.5 465.9 562 469.8L343.4 570.8C328.5 577.7 311.3 577.7 296.4 570.8L77.9 469.8C69.4 465.8 64 457.3 64 448C64 438.7 69.4 430.1 77.9 426.2z"
                  />
                </svg>
              </div>
            </div>
            <div class="stat-number" id="totalGroups">0</div>
          </div>
        </div>
      </div>

      <!-- Search and Filter Section -->
      <div class="search-section-product">
        <div class="search-bar">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#a69b99"
            stroke-width="1"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0 -14 0" />
            <path d="M21 21l-6 -6" />
          </svg>
          <input
            type="text"
            id="searchInput"
            placeholder="Tìm theo mã, tên, nhóm..."
          />
        </div>
        <div class="view-controls-product">
          <button class="view-btn-product active" id="tableViewBtn">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="#6259ee"
            >
              <rect x="3" y="4" width="18" height="3" rx="1.5" />
              <rect x="3" y="10.5" width="18" height="3" rx="1.5" />
              <rect x="3" y="17" width="18" height="3" rx="1.5" />
            </svg>
          </button>
          <button class="view-btn-product" id="gridViewBtn">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="#6259ee"
            >
              <rect x="3" y="4" width="7" height="7" rx="2" />
              <rect x="14" y="4" width="7" height="7" rx="2" />
              <rect x="14" y="13" width="7" height="7" rx="2" />
              <rect x="3" y="13" width="7" height="7" rx="2" />
            </svg>
          </button>
          <div
            class="custom-multiselect"
            style="position: relative; min-width: 220px"
          >
            <div
              id="statusInput"
              class="multiselect-input"
              style="
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 8px;
                border: 1px solid #ddd;
                border-radius: 8px;
                padding: 8px 12px;
                cursor: pointer;
              "
            >
              <span id="statusSelectedText" style="color: #999"
                >Select statuses...</span
              >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 640 640"
                fill="#666"
              >
                <path
                  d="M297.4 470.6C309.9 483.1 330.2 483.1 342.7 470.6L534.7 278.6C547.2 266.1 547.2 245.8 534.7 233.3C522.2 220.8 501.9 220.8 489.4 233.3L320 402.7L150.6 233.4C138.1 220.9 117.8 220.9 105.3 233.4C92.8 245.9 92.8 266.2 105.3 278.7L297.3 470.7z"
                />
              </svg>
            </div>
            <div
              id="statusDropdown"
              class="multiselect-dropdown"
              style="
                position: absolute;
                top: 42px;
                left: 0;
                right: 0;
                background: #fff;
                border: 1px solid #eee;
                box-shadow: 0 4px 12px #0001;
                border-radius: 8px;
                padding: 8px;
                display: none;
                z-index: 1000;
              "
            >
              <label
                style="
                  display: flex;
                  align-items: center;
                  gap: 8px;
                  padding: 6px 8px;
                  border-bottom: 1px dashed #eee;
                "
              >
                <input type="checkbox" id="statusSelectAll" />
                <strong>Select all</strong>
              </label>
              <div
                id="statusOptions"
                style="
                  display: flex;
                  flex-direction: column;
                  gap: 4px;
                  padding-top: 4px;
                "
              ></div>
            </div>
          </div>

          <div
            class="custom-multiselect"
            style="position: relative; min-width: 220px"
          >
            <div
              id="typeInput"
              class="multiselect-input"
              style="
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 8px;
                border: 1px solid #ddd;
                border-radius: 8px;
                padding: 8px 12px;
                cursor: pointer;
              "
            >
              <span id="typeSelectedText" style="color: #999"
                >Select types...</span
              >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 640 640"
                fill="#666"
              >
                <path
                  d="M297.4 470.6C309.9 483.1 330.2 483.1 342.7 470.6L534.7 278.6C547.2 266.1 547.2 245.8 534.7 233.3C522.2 220.8 501.9 220.8 489.4 233.3L320 402.7L150.6 233.4C138.1 220.9 117.8 220.9 105.3 233.4C92.8 245.9 92.8 266.2 105.3 278.7L297.3 470.7z"
                />
              </svg>
            </div>
            <div
              id="typeDropdown"
              class="multiselect-dropdown"
              style="
                position: absolute;
                top: 42px;
                left: 0;
                right: 0;
                background: #fff;
                border: 1px solid #eee;
                box-shadow: 0 4px 12px #0001;
                border-radius: 8px;
                padding: 8px;
                display: none;
                z-index: 1000;
              "
            >
              <label
                style="
                  display: flex;
                  align-items: center;
                  gap: 8px;
                  padding: 6px 8px;
                  border-bottom: 1px dashed #eee;
                "
              >
                <input type="checkbox" id="typeSelectAll" />
                <strong>Select all</strong>
              </label>
              <div
                id="typeOptions"
                style="
                  display: flex;
                  flex-direction: column;
                  gap: 4px;
                  padding-top: 4px;
                "
              ></div>
            </div>
          </div>
          <button class="refresh-btn">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#000000"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M19.933 13.041a8 8 0 1 1 -9.925 -8.788c3.899 -1 7.935 1.007 9.425 4.747"
              />
              <path d="M20 4v5h-5" />
            </svg>
            Làm mới
          </button>
        </div>
      </div>

      <!-- Grid View -->
      <div class="grid-view" id="gridView">
        <!-- JS sẽ render grid-view ở đây -->
      </div>

      <!-- Table View -->
      <div class="table-section" id="tableView">
        <table class="data-table">
          <thead>
            <tr>
              <th>Mã SP</th>
              <th>Tên Sản Phẩm</th>
              <th style="text-align: center">Loại</th>
              <th style="text-align: center">Nhóm</th>
              <th style="text-align: center">ĐV Cơ Sở</th>
              <th style="text-align: center">Trạng Thái</th>
              <th>Cập Nhật</th>
              <th style="text-align: center">Thao Tác</th>
            </tr>
          </thead>
          <tbody id="productTableBody">
            <!-- JS sẽ render table-view ở đây -->
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="pagination-section">
        <div class="pagination-controls">
          <button id="prevPageBtn" class="pagination-btn" onclick="prevPage()">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <span id="pageInfo" class="page-info">Trang 1 / 1</span>
          <button id="nextPageBtn" class="pagination-btn" onclick="nextPage()">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </div>
    </div>
    <!-- Product Detail Modal -->
    <div
      id="productDetailModal"
      style="
        display: none;
        position: fixed;
        z-index: 9999;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.25);
        align-items: center;
        justify-content: center;
      "
    >
      <div
        style="
          background: #fff;
          border-radius: 12px;
          max-width: 600px;
          width: 90vw;
          margin: 40px auto;
          padding: 32px 24px;
          box-shadow: 0 2px 24px #0002;
          position: relative;
        "
        id="productDetailBody"
      >
        <!-- JS will render product details here -->
      </div>
    </div>
  </body>
</html>
