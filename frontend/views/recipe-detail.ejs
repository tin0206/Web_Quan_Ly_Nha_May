<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chi tiết Công thức #<%= recipeId %></title>
    <link rel="stylesheet" href="/css/main_style.css" />
    <link rel="stylesheet" href="/css/recipe_detail_style.css" />
    <script src="/config.js" defer></script>
    <script type="module" src="/js/production_recipe_detail.js" defer></script>
  </head>
  <body>
    <div class="topBar">
      <a href="/" class="nav-left">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12.707 2.293l9 9c.63 .63 .184 1.707 -.707 1.707h-1v6a3 3 0 0 1 -3 3h-1v-7a3 3 0 0 0 -2.824 -2.995l-.176 -.005h-2a3 3 0 0 0 -3 3v7h-1a3 3 0 0 1 -3 -3v-6h-1c-.89 0 -1.337 -1.077 -.707 -1.707l9 -9a1 1 0 0 1 1.414 0m.293 11.707a1 1 0 0 1 1 1v7h-4v-7a1 1 0 0 1 .883 -.993l.117 -.007z"
          />
        </svg>
        <span>DashBoard</span>
      </a>
      <div class="nav-breadcrumb">
        <a href="/recipes" style="text-decoration: none; color: inherit"
          >Công Thức</a
        >
      </div>
    </div>
    <div class="main-container">
      <div class="header-container">
        <a class="back-btn" href="/recipes">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#999999"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12l14 0" />
            <path d="M5 12l6 6" />
            <path d="M5 12l6 -6" />
          </svg>
        </a>
        <div class="header-text">
          <h1>Recipe Detail</h1>
          <p>
            ID:
            <strong><%= recipeId %></strong>
          </p>
        </div>
      </div>
      <div>
        <div id="recipeDetails" style="display: block">
          <div
            style="
              background: #fff;
              border-radius: 8px;
              padding: 30px;
              box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
              margin: 0 auto;
            "
          >
            <div
              style="
                display: grid;
                grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
                gap: 20px;
                text-align: left;
              "
            >
              <div>
                <label style="font-weight: bold; color: #666"
                  >Mã Công Thức</label
                >
                <p style="margin: 5px 0; font-size: 16px" id="detailRecipeCode">
                  -
                </p>
              </div>
              <div>
                <label style="font-weight: bold; color: #666"
                  >Tên Công Thức</label
                >
                <p style="margin: 5px 0; font-size: 16px" id="detailRecipeName">
                  -
                </p>
              </div>
              <div>
                <label style="font-weight: bold; color: #666">Phiên Bản</label>
                <p
                  style="margin: 5px 0; font-size: 16px"
                  id="detailRecipeVersion"
                >
                  -
                </p>
              </div>
              <div>
                <label style="font-weight: bold; color: #666">Trạng Thái</label>
                <p
                  style="margin: 5px 0; font-size: 16px"
                  id="detailRecipeStatus"
                >
                  -
                </p>
              </div>
              <div>
                <label style="font-weight: bold; color: #666">Cập Nhật</label>
                <p
                  style="margin: 5px 0; font-size: 16px"
                  id="detailRecipeLastUpdated"
                >
                  -
                </p>
              </div>
              <div>
                <label style="font-weight: bold; color: #666"
                  >Mã Sản Phẩm</label
                >
                <p
                  style="margin: 5px 0; font-size: 16px"
                  id="detailRecipeProductCode"
                >
                  -
                </p>
              </div>
              <div>
                <label style="font-weight: bold; color: #666"
                  >Tên Sản Phẩm</label
                >
                <p
                  style="margin: 5px 0; font-size: 16px"
                  id="detailRecipeProductName"
                >
                  -
                </p>
              </div>
            </div>
          </div>
        </div>
        <div id="RecipeProcesses" class="main-container"></div>
      </div>
    </div>
  </body>
</html>
